# agentsfleet Runner — host-resident execution-plane daemon.
# Leases work from the agentsfleetd control plane over HTTPS, runs each event in a
# forked sandboxed child, and reports back. Holds zero datastore credentials.
#
# Install:
#   sudo cp agentsfleet-runner.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now agentsfleet-runner

[Unit]
Description=agentsfleet Runner
Documentation=https://docs.agentsfleet.net
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/agentsfleet-runner
Restart=always
RestartSec=5
# A stopped runner's in-flight lease is reclaimed by the control plane
# (lease_expires_at + fencing_token), so a bounded stop never loses or
# double-runs work; the timeout just lets an in-flight child finish.
TimeoutStopSec=300
KillMode=mixed

# Required runner config — provisioned per host into the env file below by the
# runner bootstrap playbook (never committed; the runner-token is a secret):
#   AGENTSFLEET_API_URL       — agentsfleetd HTTPS API base, e.g. https://api.agentsfleet.net
#   AGENTSFLEET_RUNNER_TOKEN  — pre-minted `agt_r…` token (Option B): the platform
#                          admin mints it via `POST /v1/runners` on the live
#                          control plane and stores it in 1Password under
#                          `…/agent-…-worker-ant/runner-token`; the daemon
#                          authenticates with it directly and NEVER self-registers
#   RUNNER_HOST_ID       — stable machine identifier (reuse the host's vault
#                          `hostname` field for consistency)
#   (optional) RUNNER_SANDBOX_TIER (prod should set landlock_full; release
#                                   builds reject dev_none),
#              RUNNER_WORKSPACE_BASE,
#              RUNNER_NETWORK_POLICY (allow_all is the current default and gives
#                                    full outbound egress; deny_all_egress gives
#                                    no outbound egress; allow_list_egress is the
#                                    enforced allow-list posture and currently
#                                    fails closed until egress wiring lands),
#              RUNNER_WORKER_COUNT  (concurrent leased agents per host; default 1
#                                    = one agent at a time. Size to the host's
#                                    spare cores/memory; clamped to [1, 64]. A
#                                    larger N lifts per-host throughput but widens
#                                    the failure domain — one host loss drops N
#                                    in-flight runs, not 1, all re-leased to
#                                    healthy hosts)
# Bootstrap order (chicken-and-egg): the updated agentsfleetd (with the platform-
# admin enrollment gate) must be deployed FIRST; only then can an admin mint a
# `agt_r` for this host. Until that's done, DEV_WORKER_READY stays `false`.
EnvironmentFile=-/etc/default/agentsfleet-runner

# Ensure the sandbox runtime directory exists.
RuntimeDirectory=agent
RuntimeDirectoryMode=0755

# Security hardening — the runner forks bwrap user-namespace sandboxes per lease
# (no suid needed). Mirrors the isolation the standalone sandbox sidecar carried before
# the engine folded into the runner.
NoNewPrivileges=yes
ProtectSystem=strict
ReadWritePaths=/run/agent /sys/fs/cgroup /tmp
ProtectHome=yes

[Install]
WantedBy=multi-user.target
