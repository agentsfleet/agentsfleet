.{
    .name = .agentsfleetd,
    .version = "0.22.0",
    .minimum_zig_version = "0.16.0",
    .fingerprint = 0x263fc42fde813fea,
    .dependencies = .{
        // Fork release agentsfleet/nullclaw v2026.5.29-zmb.4 — current upstream
        // main plus the maintained fork patches, now carried on the fork's main:
        //   - cumulative prompt/completion token-split accessors with normalization,
        //     reset, and restoration so the runner's by-side billing stays complete;
        //   - Server-Side Request Forgery (SSRF)-validated address pinning on the
        //     non-streaming POST dials, including direct routing past environment
        //     proxies so proxy-side DNS cannot bypass curl --resolve.
        // We have no push/release rights on upstream nullclaw/nullclaw, so the
        // patches ride our fork. Drop this pin and return to the upstream tag when
        // upstream exposes split accessors AND re-threads the resolve pin.
        .nullclaw = .{
            .url = "git+https://github.com/agentsfleet/nullclaw.git?ref=v2026.5.29-zmb.4#e00bba78395698dd97a56e5c62feb9cd14a3fef7",
            .hash = "nullclaw-2026.5.29-wlZZyWeOSAHc7sgCsTFllD7aXThbRkQIOIWIF1bZy7cD",
        },
        // Fork pin agentsfleet/pg.zig over upstream karlseguin/pg.zig commit 52b9f8a,
        // patched for a Zig 0.16 pool-acquire regression: upstream
        // `Pool.acquire()` waits via `Io.Select.concurrent` — an async combinator that
        // returns `error.ConcurrencyUnavailable` on this project's threaded `Io`, so any
        // pool exhaustion 500s instead of waiting. Patched to bounded-poll the exhaustion
        // branch (see the fork's CHANGES.md, PR patch/agentsfleet-0.16). Drop this pin and
        // return to upstream once it offers a threaded-Io timed wait.
        .pg = .{
            .url = "git+https://github.com/agentsfleet/pg.zig.git?ref=patch/agentsfleet-0.16#4749b7dd97ce75a02e316aa054d8aa5845d96359",
            .hash = "pg-0.0.0-Wp_7gUC1BgDSgdQimbojEOODY3IPYv0ozwwrZinEF-Tv",
        },
        .posthog = .{
            .url = "git+https://github.com/agentsfleet/posthog-zig.git#v0.2.0",
            .hash = "posthog-0.2.0-QwvZlsuGAgBOvEKmQ-yKf77yaLyP7SeCCPanYW1pRl7X",
        },
        // zbench pinned to the zig-0.16.0 branch HEAD — the maintained branch for
        // our Zig 0.16.0 toolchain.
        // See https://github.com/hendriknielaender/zBench#compatibility-notes.
        .zbench = .{
            .url = "git+https://github.com/hendriknielaender/zBench?ref=zig-0.16.0#c24d128bfa80ec6a1b495b84ec827c6a0bec7865",
            .hash = "zbench-0.11.2-YTdc76Q_AQAxonIKZ2-H1PdcESJGwyuYylw6RkPiBqyx",
        },
        // Fork pin agentsfleet/http.zig over upstream karlseguin/http.zig commit 52eb187,
        // carrying a shared-injector ThreadPool and matched httpz/websocket worker-mode
        // wiring (see the fork's CHANGES.md, PR patch/agentsfleet-0.16). Drop this pin once
        // both patches land upstream.
        .httpz = .{
            .url = "git+https://github.com/agentsfleet/http.zig.git?ref=patch/agentsfleet-0.16#deacae7e7bf3abe22d1c315909147f39214beb1a",
            .hash = "httpz-0.0.0-PNVzrEAUCQC4g6ChaPWV5_fZMNDcDwXJqEJmCUAcGFLN",
        },
        // Fork pin agentsfleet/zig-yaml (tag v0.3.0-dev-af.1) over upstream kubkon/zig-yaml
        // commit 84d747b (0.3.0-dev): the build.zig drops the upstream YAML Test Suite
        // conformance step, whose harness (test/spec.zig) uses std APIs removed in 0.16 and
        // broke every consumer's build. We consume only the `yaml` module (see the fork's
        // CHANGES.md, PR patch/agentsfleet-0.16). Drop this pin once upstream fixes
        // test/spec.zig for 0.16.
        .zig_yaml = .{
            .url = "git+https://github.com/agentsfleet/zig-yaml.git?ref=v0.3.0-dev-af.1#11e8c661ca0730194e224b17d7418dfca0bd4841",
            .hash = "zig_yaml-0.3.0-C1161n-rAgDc4O9pSMh-qdZcbCYCyoenayg3WpzM1Z8R",
        },
        .z3 = .{
            .url = "https://codeberg.org/fellowtraveler/z3/archive/4553a640ec867ab0355a97e5513ce4ec69a90d49.tar.gz",
            .hash = "z3-0.5.0-N25-cBA7AgAS6j3pBZYNnK0NAFgm_hpNQn4odoFjbcRS",
        },
        .cache = .{
            .url = "git+https://github.com/karlseguin/cache.zig#51b9d77bec8d9f3717349e9a007ff689959f3479",
            .hash = "cache-0.0.0-winRwJu4AAD4Kf1LLubro_8Pf66vN8U4ARd0U4imAOI5",
        },
    },
    .paths = .{
        "build.zig",
        "build.zig.zon",
        "src",
        "config",
        "schema",
    },
}
