.{
    .name = .agentsfleetd,
    .version = "0.22.0",
    .minimum_zig_version = "0.16.0",
    .fingerprint = 0x263fc42fde813fea,
    .dependencies = .{
        // Fork release agentsfleet/nullclaw v2026.5.29-zmb.3 — upstream tag
        // v2026.5.29 (b25c6eb) plus two fork commits:
        //   zmb.2 — cumulative prompt/completion token-split accumulation +
        //     promptTokensUsed()/completionTokensUsed() accessors beside
        //     tokensUsed(), plus clearSessionState() zeroing both so /new and
        //     /reset don't leave by-side metering stale (the runner bills by side).
        //   zmb.3 — pin the Server-Side Request Forgery (SSRF)-validated address on
        //     the non-streaming POST dials (curlPostTimed / curlPostFormTimed): they
        //     built the resolve pin then discarded it to std.http, which re-resolves
        //     at connect time — a DNS-rebinding Time-Of-Check-To-Time-Of-Use (TOCTOU)
        //     reachable via a user-supplied base_url. Now routed through the curl
        //     --resolve path, which keeps credentials off the child argv.
        // We have no push/release rights on upstream nullclaw/nullclaw, so the
        // patches ride our fork. Drop this pin and return to the upstream tag when
        // upstream exposes split accessors AND re-threads the resolve pin.
        .nullclaw = .{
            .url = "git+https://github.com/agentsfleet/nullclaw.git?ref=v2026.5.29-zmb.3#9403f63dd300980739b0f90be24b2d938cc0d058",
            .hash = "nullclaw-2026.5.29-wlZZyduURwHCBGe4sW7dHhwfyANddVQJeCiAOKxF-4Wq",
        },
        // Fork pin agentsfleet/pg.zig (tag v0.0.0-af.1) over upstream karlseguin/pg.zig
        // commit 1aa3e3c, patched for a Zig 0.16 pool-acquire regression: upstream
        // `Pool.acquire()` waits via `Io.Select.concurrent` — an async combinator that
        // returns `error.ConcurrencyUnavailable` on this project's threaded `Io`, so any
        // pool exhaustion 500s instead of waiting. Patched to bounded-poll the exhaustion
        // branch (see the fork's CHANGES.md, PR patch/agentsfleet-0.16). Drop this pin and
        // return to upstream once it offers a threaded-Io timed wait.
        .pg = .{
            .url = "git+https://github.com/agentsfleet/pg.zig.git?ref=v0.0.0-af.1#86fdb3e5c6a199daae77c59a116f5c987c5329d8",
            .hash = "pg-0.0.0-Wp_7gZQBBwB5TqMl562eRWWcZGtOeHdgTCAUk1HYmirg",
        },
        .posthog = .{
            .url = "git+https://github.com/agentsfleet/posthog-zig.git#v0.2.0",
            .hash = "posthog-0.2.0-QwvZlsuGAgBOvEKmQ-yKf77yaLyP7SeCCPanYW1pRl7X",
        },
        // zbench pinned to the zig-0.16.0 branch HEAD — the maintained branch for
        // our Zig 0.16.0 toolchain.
        // See https://github.com/hendriknielaender/zBench#compatibility-notes.
        .zbench = .{
            .url = "git+https://github.com/hendriknielaender/zBench?ref=zig-0.16.0#c24d128bfa80ec6a1b495b84ec827c6a0bec7865",
            .hash = "zbench-0.11.2-YTdc76Q_AQAxonIKZ2-H1PdcESJGwyuYylw6RkPiBqyx",
        },
        // Fork pin agentsfleet/http.zig (tag v0.0.0-af.1) over upstream karlseguin/http.zig
        // commit f39f1ed (master), carrying two patches: (1) non-blocking Worker.deinit
        // stops the thread pool before freeing the websocket + arena (Linux shutdown UAF),
        // and (2) a shared-injector ThreadPool replacing per-thread private queues (see the
        // fork's CHANGES.md, PR patch/agentsfleet-0.16). Drop this pin once they land upstream.
        .httpz = .{
            .url = "git+https://github.com/agentsfleet/http.zig.git?ref=v0.0.0-af.1#ab27f0c0c2972dc9bce143b11c29aa0bfbf74bb8",
            .hash = "httpz-0.0.0-PNVzrO0ACQACbDKnMiq2JfmmPCWykcBgUKQsF4TpdD6f",
        },
        // Fork pin agentsfleet/zig-yaml (tag v0.3.0-dev-af.1) over upstream kubkon/zig-yaml
        // commit 84d747b (0.3.0-dev): the build.zig drops the upstream YAML Test Suite
        // conformance step, whose harness (test/spec.zig) uses std APIs removed in 0.16 and
        // broke every consumer's build. We consume only the `yaml` module (see the fork's
        // CHANGES.md, PR patch/agentsfleet-0.16). Drop this pin once upstream fixes
        // test/spec.zig for 0.16.
        .zig_yaml = .{
            .url = "git+https://github.com/agentsfleet/zig-yaml.git?ref=v0.3.0-dev-af.1#11e8c661ca0730194e224b17d7418dfca0bd4841",
            .hash = "zig_yaml-0.3.0-C1161n-rAgDc4O9pSMh-qdZcbCYCyoenayg3WpzM1Z8R",
        },
        .z3 = .{
            .url = "https://codeberg.org/fellowtraveler/z3/archive/6170f82ac8dbc377167adc818b2ec45b0cd30b9c.tar.gz",
            .hash = "z3-0.4.0-N25-cCCMAQAJwdfivwRrCFccaGnnVPk7TnWKn4S7U-5a",
        },
        .cache = .{
            .url = "git+https://github.com/karlseguin/cache.zig#51b9d77bec8d9f3717349e9a007ff689959f3479",
            .hash = "cache-0.0.0-winRwJu4AAD4Kf1LLubro_8Pf66vN8U4ARd0U4imAOI5",
        },
    },
    .paths = .{
        "build.zig",
        "build.zig.zon",
        "src",
        "config",
        "schema",
    },
}
