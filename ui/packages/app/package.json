{
  "name": "agentsfleet-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "bun run typecheck && next build",
    "start": "next start",
    "typecheck": "node ./node_modules/@typescript/native/bin/tsc --noEmit",
    "lint": "oxlint --type-aware .",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke.test.ts",
    "test:e2e": "bunx playwright test",
    "test:e2e:smoke": "bunx playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:acceptance": "bunx playwright test --config=playwright.acceptance.config.ts",
    "test:e2e:acceptance:preflight": "bunx playwright test --config=playwright.acceptance.config.ts --project=preflight",
    "test:e2e:acceptance:journeys": "bunx playwright test --config=playwright.acceptance.config.ts --project=journeys",
    "test:e2e:acceptance:operator": "bunx playwright test --config=playwright.acceptance.config.ts --project=operator-journey",
    "test:e2e:acceptance:local": "NEXT_PUBLIC_API_URL=http://localhost:3000 bunx playwright test --config=playwright.acceptance.config.ts",
    "test:e2e:acceptance:dev": "BASE_URL=https://app-dev.agentsfleet.net NEXT_PUBLIC_API_URL=https://api-dev.agentsfleet.net bunx playwright test --config=playwright.acceptance.config.ts",
    "test:e2e:acceptance:prod": "BASE_URL=https://app.agentsfleet.net NEXT_PUBLIC_API_URL=https://api.agentsfleet.net bunx playwright test --config=playwright.acceptance.config.ts",
    "qa": "bun run test && bun run test:e2e",
    "test:coverage": "vitest run --coverage",
    "qa:smoke": "bun run test:smoke && bun run test:e2e:smoke"
  },
  "dependencies": {
    "@agentsfleet/design-system": "workspace:*",
    "@assistant-ui/react": "^0.14.26",
    "@clerk/nextjs": "^7.5.16",
    "@clerk/themes": "^2.4.57",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-avatar": "1.2.2",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-separator": "1.1.11",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-tooltip": "1.2.12",
    "class-variance-authority": "0.7.1",
    "cron-parser": "^5.6.1",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "posthog-js": "^1.399.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@clerk/testing": "^2.2.6",
    "@playwright/test": "1.61.1",
    "@size-limit/preset-app": "^12.1.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript/native": "npm:typescript@7.0.2",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-istanbul": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "happy-dom": "20.10.6",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "size-limit": "^12.1.0",
    "svix": "^1.96.1",
    "tailwindcss": "^4.3.2",
    "typescript": "npm:typescript@6.0.2",
    "vitest": "4.1.10"
  }
}
