#!/usr/bin/env bash
# Pre-push: fast smoke verification. Heavy lanes live in Continuous Integration
# (CI).
#
# Stage shape:
#   1. classify pushed files (since upstream / main fork-point) into 7 flags
#   2. run matching test-unit-* lanes
#
# Surfaces:
#   - test-unit-agentsfleetd        (*.zig, schema/*.sql)
#   - test-unit-cli            (cli/*)
#   - test-unit-website        (ui/packages/website/*)
#   - test-unit-app            (ui/packages/app/*, design-system/* triggers both)
#   - test-unit-design-system  (ui/packages/design-system/*)
#
# Moved to Continuous Integration (CI)
# (.github/workflows/{test-integration,memleak}.yml):
#   - test-integration         — worker integration vs real Postgres + Redis
#   - memleak                  — valgrind / allocator leak gate
# Pre-push is the fast-smoke floor; CI is the comprehensive gate. The prior
# behaviour held the Secure Shell (SSH) session idle for 15-20 min during the
# heavier lanes, which github.com routinely dropped at pack-write time even
# though every test passed locally.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
  upstream_ref='@{u}'
else
  # No upstream yet (first push of this branch) — gate against main fork-point.
  upstream_ref="$(git merge-base HEAD main 2>/dev/null || git rev-list --max-parents=0 HEAD)"
fi

pushed_files="$(git diff --name-only "$upstream_ref"..HEAD 2>/dev/null || true)"

needs_test_zig=0
needs_test_cli=0
needs_test_website=0
needs_test_app=0
needs_test_design_system=0

while IFS= read -r f; do
  [ -z "$f" ] && continue
  case "$f" in
    *.zig|schema/*.sql)
      needs_test_zig=1 ;;
    cli/*)
      needs_test_cli=1 ;;
    ui/packages/website/*)
      needs_test_website=1 ;;
    ui/packages/app/*)
      needs_test_app=1 ;;
    ui/packages/design-system/*)
      # Design system is consumed by app — test both when design-system changes.
      needs_test_design_system=1
      needs_test_app=1 ;;
  esac
done <<< "$pushed_files"

any_needed=$(( needs_test_zig + needs_test_cli + needs_test_website + needs_test_app + needs_test_design_system ))

if [ "$any_needed" -eq 0 ]; then
  echo "pre-push: no test-relevant files since $upstream_ref — nothing to run"
  exit 0
fi

# --- Test lanes --------------------------------------------------------------
# Browser and pseudo-terminal tests are individually stable but fight for local
# runtime resources when all lanes launch at once. Keep coverage intact and run
# lanes serially so the hook is deterministic on developer laptops.
failed_names=()

run_lane() {
  local name="$1"; shift
  echo "pre-push: $*"
  if ! "$@"; then
    failed_names+=("$name")
  fi
}

[ "$needs_test_zig"           = 1 ] && run_lane test-unit-agentsfleetd        make test-unit-agentsfleetd
[ "$needs_test_cli"           = 1 ] && run_lane test-unit-cli                make test-unit-cli
[ "$needs_test_website"       = 1 ] && run_lane test-unit-website            make test-unit-website
[ "$needs_test_app"           = 1 ] && run_lane test-unit-app                make test-unit-app
[ "$needs_test_design_system" = 1 ] && run_lane test-unit-design-system      make test-unit-design-system

if [ "${#failed_names[@]}" -gt 0 ]; then
  echo "✗ pre-push: failed lanes — ${failed_names[*]}"
  exit 1
fi

exit 0
