#!/usr/bin/env bash
# Pre-commit: reject partial staging, run gitleaks, then run scoped checks
# scoped to the changed surfaces.
#
# Stage shape:
#   1. reject files with staged and unstaged edits
#   2. gitleaks --staged              (serial, always)
#   3. classify staged files by surface
#   4. make harness-verify            (serial, fast — must run before lints)
#   5. run one parallel Make graph plus the direct auth test
#
# Surfaces:
#   - lint-zig                 (*.zig, schema/*.sql)
#   - test-auth                (*.zig, schema/*.sql — src/agentsfleetd/auth/** portability gate)
#   - lint-website             (ui/packages/website/*)
#   - lint-app                 (ui/packages/app/*, design-system/* triggers both)
#   - lint-design-system       (ui/packages/design-system/*)
#   - lint-cli                 (cli/*)
#   - lint-shell               (scripts/*.sh)
#   - check-documentation-rules (public API and command help text)
#   - check-schema-gate        (schema/*.sql)
#   - check-openapi            (public/openapi/*, public/openapi.json)
#   - check-gh-actions-valid   (.github/workflows/*, Makefile, make/*.mk)
#   - check-playbooks          (playbooks/*, deploy/*, .github/workflows/* —
#                               repo-wide playbooks/ ref integrity + shellcheck
#                               + README parity; refs are executed at deploy time)
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Checks read the working tree. A partly staged file could otherwise pass with
# content that is absent from the commit.
staged_paths="$(git diff --cached --name-only --diff-filter=ACMR | sort -u)"
unstaged_paths="$(git diff --name-only --diff-filter=ACMR | sort -u)"
partial_paths="$(comm -12 <(printf '%s\n' "$staged_paths") <(printf '%s\n' "$unstaged_paths"))"
if [ -n "$partial_paths" ]; then
  echo "pre-commit: these files have staged and unstaged edits:" >&2
  while IFS= read -r path; do
    printf '  - %s\n' "$path" >&2
  done <<< "$partial_paths"
  echo "Stage each whole file before committing." >&2
  exit 1
fi

# --- gitleaks on staged content ----------------------------------------------
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit: gitleaks not installed. See https://github.com/gitleaks/gitleaks/releases" >&2
  exit 1
fi

echo "pre-commit: gitleaks protect --staged"
gitleaks protect --staged --redact --verbose --no-banner

# --- Classify staged files into per-surface flags ----------------------------
# Each flag triggers exactly one make target; design-system additionally
# triggers app (DS is consumed by app, so a DS change might break app's tsc).
staged="$(git diff --cached --name-only --diff-filter=ACMR)"

needs_lint_zig=0
needs_test_auth=0
needs_lint_website=0
needs_lint_app=0
needs_lint_design_system=0
needs_lint_cli=0
needs_lint_shell=0
needs_check_documentation=0
needs_check_openapi=0
needs_check_schema_gate=0
needs_check_gh_actions=0
needs_check_playbooks=0
needs_harness_only=0

while IFS= read -r f; do
  [ -z "$f" ] && continue
  case "$f" in
    *.zig)
      needs_lint_zig=1
      needs_test_auth=1
      needs_check_documentation=1 ;;
    schema/*.sql)
      needs_check_schema_gate=1
      needs_lint_zig=1
      needs_test_auth=1 ;;
    public/openapi/*|public/openapi.json)
      needs_check_openapi=1 ;;
    ui/packages/website/*)
      needs_lint_website=1 ;;
    ui/packages/app/*)
      needs_lint_app=1
      needs_check_documentation=1 ;;
    ui/packages/design-system/*)
      # DS is consumed by app — lint both when DS changes.
      needs_lint_design_system=1
      needs_lint_app=1 ;;
    cli/*)
      needs_lint_cli=1 ;;
    scripts/check_documentation_rules.py|scripts/check_documentation_rules_test.py|.githooks/pre-commit)
      needs_check_documentation=1 ;;
    .github/workflows/*.yml|.github/workflows/*.yaml|Makefile|make/*.mk)
      needs_check_gh_actions=1
      needs_check_documentation=1
      # A workflow / Makefile / make-fragment change can re-point or break a
      # playbooks/ reference (deploy.yml runs playbook gates at deploy time).
      needs_check_playbooks=1 ;;
    scripts/*.sh)
      needs_lint_shell=1 ;;
    playbooks/*)
      needs_check_playbooks=1 ;;
    deploy/*)
      # deploy/baremetal/deploy.sh cites playbook provisioning paths — a
      # broken ref here only fails at deploy time without this gate.
      needs_check_playbooks=1 ;;
    tests/fixtures/*)
      needs_check_documentation=1 ;;
    *.json|*.yaml|*.yml)
      # Catch-all for stray config/manifest files staged outside a known
      # surface prefix (root-level `package.json`, `docker-compose.yml`,
      # `build.zig.zon`, ad-hoc CI overlays, etc.). These can't affect
      # workflow YAML, so route them through harness-verify only —
      # actionlint + the make-target-ref sweep cost ~30s and would
      # always be wasted work for these files.
      needs_harness_only=1 ;;
  esac
done <<< "$staged"

any_needed=$(( needs_lint_zig + needs_test_auth + needs_lint_website + needs_lint_app + needs_lint_design_system + needs_lint_cli + needs_lint_shell + needs_check_documentation + needs_check_openapi + needs_check_schema_gate + needs_check_gh_actions + needs_check_playbooks + needs_harness_only ))

if [ "$any_needed" -eq 0 ]; then
  echo "pre-commit: no lint-relevant files staged, skipping harness-verify + targeted lint"
  exit 0
fi

# --- harness-verify (serial, fast — full-state gates) ------------------------
echo "pre-commit: make harness-verify"
make harness-verify

# --- Scoped checks -----------------------------------------------------------
# One Make graph lets shared prerequisites run once. The auth portability test
# has no Make target, so it runs beside that graph.
pids=()
names=()

launch() {
  local name="$1"; shift
  echo "pre-commit: $* (parallel)"
  "$@" &
  pids+=("$!")
  names+=("$name")
}

make_targets=()
[ "$needs_lint_zig"            = 1 ] && make_targets+=(lint-zig)
[ "$needs_lint_website"        = 1 ] && make_targets+=(lint-website)
[ "$needs_lint_app"            = 1 ] && make_targets+=(lint-app)
[ "$needs_lint_design_system"  = 1 ] && make_targets+=(lint-design-system)
[ "$needs_lint_cli"            = 1 ] && make_targets+=(lint-cli)
[ "$needs_lint_shell"          = 1 ] && make_targets+=(lint-shell)
[ "$needs_check_documentation" = 1 ] && make_targets+=(check-documentation-rules)
[ "$needs_check_schema_gate"   = 1 ] && make_targets+=(check-schema-gate)
[ "$needs_check_openapi"       = 1 ] && make_targets+=(check-openapi)
[ "$needs_check_gh_actions"    = 1 ] && make_targets+=(check-gh-actions-valid)
[ "$needs_check_playbooks"     = 1 ] && make_targets+=(check-playbooks)

[ "${#make_targets[@]}" -gt 0 ] && launch make-graph make -j "${make_targets[@]}"
[ "$needs_test_auth" = 1 ] && launch test-auth zig build test-auth

failed_names=()
for i in "${!pids[@]}"; do
  if ! wait "${pids[$i]}"; then
    failed_names+=("${names[$i]}")
  fi
done

if [ "${#failed_names[@]}" -gt 0 ]; then
  echo "✗ pre-commit: failed lanes — ${failed_names[*]}"
  exit 1
fi

# Force exit 0 even if a stray short-circuit ended on a falsy test (bash
# `[ X -eq 1 ] && { … }` final-statement quirk under set -e).
exit 0
