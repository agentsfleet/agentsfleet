{
  "name": "@agentsfleet/cli",
  "version": "0.22.0",
  "description": "agentsfleet CLI",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentsfleet/agentsfleet"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "agentsfleet": "./dist/bin/agentsfleet.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.14"
  },
  "scripts": {
    "test": "npm run build && node ./scripts/enforce-coverage.mjs",
    "test:coverage": "npm run build && bun test --coverage",
    "test:acceptance": "npm run build && bun test test/acceptance --timeout 120000",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test scripts && node ./scripts/audit-runtime-imports.mjs && node ./scripts/audit-const-names.mjs && tsc --noEmit",
    "lint:fix": "oxlint src test scripts --fix && node ./scripts/audit-runtime-imports.mjs && node ./scripts/audit-const-names.mjs && tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vercel/detect-agent": "^1.2.3",
    "commander": "^15.0.0",
    "effect": "4.0.0-beta.97",
    "posthog-node": "^5.40.0",
    "uuid": "^14.0.1"
  },
  "license": "MIT",
  "devDependencies": {
    "@clerk/testing": "^2.2.6",
    "@playwright/test": "1.61.1",
    "@types/node": "^26.1.1",
    "@types/uuid": "^11.0.0",
    "bun-types": "^1.3.14",
    "oxlint": "^1.73.0",
    "playwright": "^1.61.1",
    "typescript": "7.0.2"
  }
}
