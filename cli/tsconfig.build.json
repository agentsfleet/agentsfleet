{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": false,
    "sourceMap": false,
    "removeComments": false
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "skills",
    ".tmp",
    "coverage",
    "dist",
    "test",
    "bin",
    "scripts"
  ]
}
